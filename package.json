{
  "name": "protonmail-cli",
  "version": "0.1.0",
  "description": "ProtonMail CLI via Proton Bridge IMAP/SMTP — terminal client and library",
  "type": "module",
  "bin": {
    "protonmail-cli": "./dist/cli.js",
    "pm": "./dist/cli.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "prepublishOnly": "npm run build && npm run typecheck && npm run test"
  },
  "keywords": [
    "protonmail",
    "proton",
    "email",
    "imap",
    "smtp",
    "cli",
    "proton-bridge",
    "mail"
  ],
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": ""
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "columnify": "^1.6.0",
    "commander": "^14.0.0",
    "imapflow": "^1.2.0",
    "mailparser": "^3.7.0",
    "nodemailer": "^6.9.0",
    "@inquirer/prompts": "^7.0.0",
    "@napi-rs/keyring": "^1.1.0",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@types/columnify": "^1.5.0",
    "@types/mailparser": "^3.4.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.0",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
